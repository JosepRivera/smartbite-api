{
	"extends": "@tsconfig/node24/tsconfig.json",
	"compilerOptions": {
		"emitDecoratorMetadata": true,
		"experimentalDecorators": true,
		"outDir": "./dist",
		"baseUrl": "./",
		"paths": {
			"@/*": ["src/*"]
		},
		"types": ["vitest/globals"],
		"incremental": false
	},
	"include": ["src/**/*", "test/**/*", "prisma/seed.ts"],
	"exclude": ["node_modules", "dist"]
}
