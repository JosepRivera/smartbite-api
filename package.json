{
  "name": "smartbite-api",
  "version": "0.0.1",
  "description": "Backend SmartBite — Tecsup 2026-1",
  "author": "JosepRivera",
  "private": true,
  "scripts": {
    "start:dev": "nest start --watch",
    "build": "nest build",
    "lint": "biome check --write ./src ./test",
    "dev": "docker compose up",
    "dev:build": "docker compose up --build",
    "stop": "docker compose down",
    "db:migrate": "docker exec -it smartbite-app-dev pnpm prisma migrate dev",
    "db:gen": "docker exec smartbite-app-dev pnpm prisma generate",
    "db:seed": "docker exec smartbite-app-dev pnpm tsx prisma/seed.ts",
    "db:reset": "docker exec -it smartbite-app-dev pnpm prisma migrate reset",
    "shell": "docker exec -it smartbite-app-dev sh",
    "clean": "docker compose down -v",
    "test": "vitest run --project unit",
    "test:e2e": "docker compose -f docker-compose.test.yml up --build --abort-on-container-exit --exit-code-from app-test --remove-orphans",
    "test:e2e:down": "docker compose -f docker-compose.test.yml down -v",
    "test:cov": "vitest run --project unit --coverage",
    "test:watch": "vitest --project unit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.86.1",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.18",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.1",
    "groq-sdk": "^1.1.2",
    "helmet": "^8.1.0",
    "jose": "^6.2.2",
    "ms": "^2.1.3",
    "nestjs-zod": "^5.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@nestjs/cli": "^11.0.18",
    "@nestjs/schematics": "^11.0.10",
    "@nestjs/testing": "^11.1.18",
    "@tsconfig/node24": "^24.0.4",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/ms": "^2.1.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.12.2",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.3",
    "prisma": "^7.7.0",
    "supertest": "^7.2.2",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  },
  "packageManager": "pnpm@10.31.0"
}
