# ═══════════════════════════════════════════════════════
# SmartBite API — Variables de entorno
# ═══════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────
# PostgreSQL
# ───────────────────────────────────────────────────────
POSTGRES_USER=smartbite_user
POSTGRES_PASSWORD=TODO_cambia_esta_password
POSTGRES_DB=smartbite_db
POSTGRES_PORT=5432

# DATABASE_URL la construye Docker Compose automáticamente.
# Solo descomenta y rellena esta línea si corres la app
# fuera de Docker (ej: pnpm start:dev directo en tu máquina):
# DATABASE_URL=postgresql://smartbite_user:TODO@localhost:5432/smartbite_db?schema=public

# ───────────────────────────────────────────────────────
# Servidor
# ───────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ───────────────────────────────────────────────────────
# JWT — Autenticación
# Genera JWT_SECRET con: openssl rand -base64 64
# ───────────────────────────────────────────────────────
JWT_SECRET=TODO_genera_un_secret_largo_y_aleatorio
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=7d

# ───────────────────────────────────────────────────────
# Seguridad
# ───────────────────────────────────────────────────────
BCRYPT_ROUNDS=10
CORS_ORIGIN=http://localhost:3000

# ───────────────────────────────────────────────────────
# Claude API (Anthropic) — IA-1, IA-2, IA-3, VOZ-1
# Obtén tu API Key en: https://console.anthropic.com
#
# Modelos disponibles:
#   claude-haiku-4-5-20251001   ← recomendado producción (económico)
#   claude-sonnet-4-5           ← recomendado desarrollo/demo (mejor calidad)
# ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=TODO_sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5
CLAUDE_TIMEOUT_INTERACTIVE=10000
CLAUDE_TIMEOUT_BATCH=30000

# ───────────────────────────────────────────────────────
# Groq Whisper API — VOZ-1
# Obtén tu API Key en: https://console.groq.com
# ───────────────────────────────────────────────────────
GROQ_API_KEY=TODO_gsk_...
GROQ_WHISPER_MODEL=whisper-large-v3-turbo
GROQ_TIMEOUT=15000