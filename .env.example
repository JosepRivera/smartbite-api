# ═══════════════════════════════════════════════════════
# SmartBite API — Variables de entorno (EJEMPLO)
# ═══════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────
# PostgreSQL
# ───────────────────────────────────────────────────────
POSTGRES_USER=smartbite_admin
POSTGRES_PASSWORD=example_secure_password_123
POSTGRES_DB=smartbite_db
POSTGRES_PORT=5432

# DATABASE_URL la construye Docker Compose automáticamente.
# Solo descomenta si corres la app fuera de Docker:
# DATABASE_URL=postgresql://smartbite_admin:example_secure_password_123@localhost:5432/smartbite_db?schema=public

# ───────────────────────────────────────────────────────
# Servidor
# ───────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ───────────────────────────────────────────────────────
# JWT — Autenticación
# Genera uno real con:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ───────────────────────────────────────────────────────
JWT_SECRET=example_super_long_random_jwt_secret_key_change_me
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=7d

# ───────────────────────────────────────────────────────
# Seguridad
# ───────────────────────────────────────────────────────
BCRYPT_ROUNDS=10
CORS_ORIGIN=http://localhost:3000

# ───────────────────────────────────────────────────────
# Claude API (Anthropic)
# ───────────────────────────────────────────────────────
# Obtén tu API Key en: https://console.anthropic.com
# Ejemplo de formato: sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-example-key-change-me
ANTHROPIC_MODEL=claude-sonnet-4-5
CLAUDE_TIMEOUT_INTERACTIVE=10000
CLAUDE_TIMEOUT_BATCH=30000

# ───────────────────────────────────────────────────────
# Groq Whisper API
# ───────────────────────────────────────────────────────
# Obtén tu API Key en: https://console.groq.com
# Ejemplo de formato: gsk_xxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY=gsk_example_key_change_me
GROQ_WHISPER_MODEL=whisper-large-v3-turbo
GROQ_TIMEOUT=15000