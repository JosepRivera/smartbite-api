generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "commonjs"
  previewFeatures = ["views"]
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Role {
  OWNER
  CASHIER
  WAITER
  COOK

  @@map("role_enum")
}

enum SaleStatus {
  OPEN
  PAID_CASH
  PAID_YAPE
  PAID_PLIN
  PAID_AGORA
  CANCELLED

  @@map("sale_status_enum")
}

enum PaymentSource {
  YAPE
  PLIN
  AGORA

  @@map("payment_source_enum")
}

// ─────────────────────────────────────────────
// Tablas
// ─────────────────────────────────────────────

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  username  String   @unique
  password  String
  role      Role
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  refreshTokens        RefreshToken[]
  sales                Sale[]                @relation("SaleCreatedBy")
  salesUpdated         Sale[]                @relation("SaleUpdatedBy")
  salesCancelled       Sale[]                @relation("SaleCancelledBy")
  expenses             Expense[]
  cashCloses           CashClose[]
  deviceTokens         DeviceToken[]
  paymentNotifications PaymentNotification[] @relation("NotificationReviewedBy")

  @@index([role], map: "idx_users_role")
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_refresh_tokens_user_id")
  @@map("refresh_tokens")
}

model Product {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  price     Decimal  @db.Decimal(10, 2)
  category  String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  saleItems             SaleItem[]
  recipes               Recipe[]
  referenceBaselines    ReferenceBaseline[]
  dailyProductionPlans  DailyProductionPlan[]

  @@index([isActive], map: "idx_products_is_active")
  @@index([category], map: "idx_products_category")
  @@map("products")
}

model Ingredient {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  unit        String
  stock       Decimal  @default(0) @db.Decimal(10, 3)
  minStock    Decimal  @default(0) @map("min_stock") @db.Decimal(10, 3)
  costPerUnit Decimal  @map("cost_per_unit") @db.Decimal(10, 4)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  recipes Recipe[]

  // idx_ingredients_low_stock es un índice parcial (WHERE stock <= min_stock)
  // declarado en prisma/sql/03_indexes.sql — no se puede expresar en Prisma schema.
  @@index([stock], map: "idx_ingredients_stock")
  @@map("ingredients")
}

model Recipe {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId    String  @map("product_id") @db.Uuid
  ingredientId String  @map("ingredient_id") @db.Uuid
  quantity     Decimal @db.Decimal(10, 4)

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Restrict)

  @@unique([productId, ingredientId], map: "uq_recipes_product_ingredient")
  @@index([productId], map: "idx_recipes_product_id")
  @@map("recipes")
}

model Sale {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  status       SaleStatus @default(OPEN)
  total        Decimal    @db.Decimal(10, 2)
  tableNumber  String?    @map("table_number") @db.VarChar(10)
  customerName String?    @map("customer_name")
  userId       String     @map("user_id") @db.Uuid
  updatedBy    String?    @map("updated_by") @db.Uuid
  cancelledBy  String?    @map("cancelled_by") @db.Uuid
  cancelledAt  DateTime?  @map("cancelled_at") @db.Timestamptz
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  user            User       @relation("SaleCreatedBy", fields: [userId], references: [id], onDelete: Restrict)
  updatedByUser   User?      @relation("SaleUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)
  cancelledByUser User?      @relation("SaleCancelledBy", fields: [cancelledBy], references: [id], onDelete: SetNull)
  items           SaleItem[]

  // idx_sales_open_today es índice parcial (WHERE status = 'OPEN')
  // declarado en prisma/sql/03_indexes.sql
  @@index([status], map: "idx_sales_status")
  @@index([tableNumber], map: "idx_sales_table_number")
  @@index([userId], map: "idx_sales_user_id")
  @@index([createdAt], map: "idx_sales_created_at")
  @@map("sales")
}

model SaleItem {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  saleId     String  @map("sale_id") @db.Uuid
  productId  String  @map("product_id") @db.Uuid
  quantity   Int
  unitPrice  Decimal @map("unit_price") @db.Decimal(10, 2)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([saleId], map: "idx_sale_items_sale_id")
  @@index([productId], map: "idx_sale_items_product_id")
  @@map("sale_items")
}

model Expense {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  description String
  amount      Decimal  @db.Decimal(10, 2)
  category    String
  userId      String   @map("user_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([createdAt], map: "idx_expenses_created_at")
  @@index([userId], map: "idx_expenses_user_id")
  @@map("expenses")
}

model CashClose {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date           DateTime  @db.Date
  cashIncome     Decimal   @default(0) @map("cash_income") @db.Decimal(10, 2)
  digitalIncome  Decimal   @default(0) @map("digital_income") @db.Decimal(10, 2)
  totalIncome    Decimal   @map("total_income") @db.Decimal(10, 2)
  totalExpenses  Decimal   @default(0) @map("total_expenses") @db.Decimal(10, 2)
  netProfit      Decimal   @map("net_profit") @db.Decimal(10, 2)
  closedBy       String    @map("closed_by") @db.Uuid
  parentCloseId  String?   @map("parent_close_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  // date NO tiene @unique aquí — la unicidad sobre cierres normales
  // la gestiona el índice parcial uq_cash_closes_date_normal en
  // prisma/sql/03_indexes.sql (WHERE parent_close_id IS NULL)

  closedByUser  User       @relation(fields: [closedBy], references: [id], onDelete: Restrict)
  parentClose   CashClose? @relation("CashCloseAdjustments", fields: [parentCloseId], references: [id], onDelete: Restrict)
  adjustments   CashClose[] @relation("CashCloseAdjustments")

  @@map("cash_closes")
}

model PaymentNotification {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  notificationId String        @unique @map("notification_id")
  amount         Decimal       @db.Decimal(10, 2)
  senderName     String        @map("sender_name")
  source         PaymentSource
  rawText        String        @map("raw_text") @db.VarChar(500)
  isReviewed     Boolean       @default(false) @map("is_reviewed")
  reviewedBy     String?       @map("reviewed_by") @db.Uuid
  reviewedAt     DateTime?     @map("reviewed_at") @db.Timestamptz
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz

  reviewedByUser User? @relation("NotificationReviewedBy", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([notificationId], map: "idx_payment_notifications_notification_id")
  @@index([isReviewed], map: "idx_payment_notifications_is_reviewed")
  @@index([createdAt], map: "idx_payment_notifications_created_at")
  @@map("payment_notifications")
}

model DeviceToken {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  apiKeyHash   String    @unique @map("api_key_hash")
  isActive     Boolean   @default(true) @map("is_active")
  registeredBy String    @map("registered_by") @db.Uuid
  lastUsedAt   DateTime? @map("last_used_at") @db.Timestamptz
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  registeredByUser User @relation(fields: [registeredBy], references: [id], onDelete: Restrict)

  @@index([isActive], map: "idx_device_tokens_is_active")
  @@map("device_tokens")
}

model ReferenceBaseline {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId  String   @map("product_id") @db.Uuid
  dayOfWeek  Int      @map("day_of_week")
  quantity   Decimal  @db.Decimal(10, 2)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, dayOfWeek], map: "uq_reference_baselines_product_day")
  @@map("reference_baselines")
}

model DailyProductionPlan {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date             DateTime @db.Date
  productId        String   @map("product_id") @db.Uuid
  quantity         Decimal  @db.Decimal(10, 2)
  predictionSource String   @map("prediction_source") @db.VarChar(50)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([date, productId], map: "uq_daily_production_plans_date_product")
  @@index([date], map: "idx_daily_production_plans_date")
  @@map("daily_production_plans")
}

// ─────────────────────────────────────────────
// Vistas SQL — creadas por prisma/sql/01_views.sql via Docker
// previewFeature "views" requerido en el generator
// ─────────────────────────────────────────────

view DailySummary {
  cashIncome    Decimal @map("cash_income")    @db.Decimal
  digitalIncome Decimal @map("digital_income") @db.Decimal
  totalIncome   Decimal @map("total_income")   @db.Decimal
  openOrders    Int     @map("open_orders")
  paidOrders    Int     @map("paid_orders")

  @@unique([cashIncome, digitalIncome, totalIncome])
  @@map("v_daily_summary")
}

view ProductProfitability {
  id               String  @unique @db.Uuid
  name             String
  category         String
  salePrice        Decimal @map("sale_price")       @db.Decimal
  unitCost         Decimal @map("unit_cost")         @db.Decimal
  unitMargin       Decimal @map("unit_margin")       @db.Decimal
  marginPercentage Decimal @map("margin_percentage") @db.Decimal

  @@map("v_product_profitability")
}